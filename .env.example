# ─── Database ───────────────────────────────────────────────
# Local dev: start with `docker compose up db -d`, then use this URL:
# Docker deploy: the app container uses db hostname internally (hardcoded in compose)
DATABASE_URL="postgresql://taschenkonto:taschenkonto@localhost:5432/taschenkonto"

# ─── Docker ────────────────────────────────────────────────
# Password for the PostgreSQL container (defaults to "taschenkonto" if unset)
# POSTGRES_PASSWORD="change-me-in-production"
# Host port for the app (defaults to 3000)
# APP_PORT=3000

# ─── Auth.js (Magic Link) ──────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-generate-with-openssl-rand-base64-32"
AUTH_TRUST_HOST=true

# Resend API key for sending magic link emails
# Get yours at https://resend.com → API Keys
AUTH_RESEND_KEY=""

# Sender address for login emails (must be verified in Resend)
# For testing: Resend provides onboarding@resend.dev by default
AUTH_EMAIL_FROM="Taschenkonto <noreply@taschenkonto.de>"

# ─── Kiosk Session ─────────────────────────────────────────
# Separate JWT secret for child PIN sessions
# Generate with: openssl rand -base64 32
KIOSK_SESSION_SECRET="change-me-generate-with-openssl-rand-base64-32"

# ─── Cron ───────────────────────────────────────────────────
# Secret header value to protect /api/cron/* endpoints
CRON_SECRET="change-me-random-cron-secret"
