generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Enums ---

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  ADJUSTMENT
  ALLOWANCE
  CHORE_REWARD
  INVESTMENT_DEPOSIT
  INVESTMENT_WITHDRAWAL
  INTEREST
}

enum TransactionOrigin {
  MANUAL
  ALLOWANCE_RULE
  CHORE_COMPLETION
  INVESTMENT
}

enum AllowanceFrequency {
  WEEKLY
  MONTHLY
}

enum ChoreRecurrence {
  ONE_TIME
  DAILY
  WEEKLY
  MONTHLY
}

enum CompletionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum InvestmentType {
  TAGESGELD
  FESTGELD
}

enum InvestmentStatus {
  ACTIVE
  MATURED
  WITHDRAWN
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
}

// --- Auth.js Models ---

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  emailVerified  DateTime?
  name           String?
  image          String?
  hashedPassword String?
  familyId       String?
  family         Family?   @relation(fields: [familyId], references: [id], onDelete: Cascade)
  accounts       Account[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([familyId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Family {
  id                      String         @id @default(cuid())
  name                    String
  currency                String         @default("EUR")
  timezone                String         @default("Europe/Berlin")
  kioskInvestmentsEnabled Boolean        @default(false)
  children                ChildAccount[]
  parents                 User[]
  chores                  Chore[]
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
}

model ChildAccount {
  id               String            @id @default(cuid())
  name             String
  avatarEmoji      String            @default("🧒")
  color            String?
  hashedPin        String
  pinChangedAt     DateTime?
  familyId         String
  family           Family            @relation(fields: [familyId], references: [id], onDelete: Cascade)
  transactions     Transaction[]
  allowanceRules   AllowanceRule[]
  choreAssignments ChoreAssignment[]
  savingGoals      SavingGoal[]
  investments      Investment[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([familyId])
}

model LoginAttempt {
  id             String   @id @default(cuid())
  rateKey        String   @unique
  count          Int      @default(0)
  firstAttemptAt DateTime @default(now())
  lockedUntil    DateTime?

  @@index([rateKey])
}

model Transaction {
  id                    String            @id @default(cuid())
  amountCents           Int
  type                  TransactionType
  origin                TransactionOrigin
  description           String
  childAccountId        String
  childAccount          ChildAccount      @relation(fields: [childAccountId], references: [id], onDelete: Cascade)
  choreCompletionId     String?           @unique
  choreCompletion       ChoreCompletion?  @relation(fields: [choreCompletionId], references: [id])
  investmentId          String?
  investment            Investment?       @relation(fields: [investmentId], references: [id])
  createdByUserId       String?
  revertedTransactionId String?           @unique
  createdAt             DateTime          @default(now())

  @@index([childAccountId])
  @@index([createdAt])
  @@index([investmentId])
}

model AllowanceRule {
  id             String             @id @default(cuid())
  amountCents    Int
  frequency      AllowanceFrequency
  dayOfWeek      Int?               // 0-6 for weekly
  dayOfMonth     Int?               // 1-31 for monthly
  isActive       Boolean            @default(true)
  lastRunAt      DateTime?
  nextRunAt      DateTime
  childAccountId String
  childAccount   ChildAccount       @relation(fields: [childAccountId], references: [id], onDelete: Cascade)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([childAccountId])
  @@index([nextRunAt])
}

model Chore {
  id          String            @id @default(cuid())
  title       String
  description String?
  rewardCents Int
  recurrence  ChoreRecurrence   @default(ONE_TIME)
  familyId    String
  family      Family            @relation(fields: [familyId], references: [id], onDelete: Cascade)
  assignments ChoreAssignment[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([familyId])
}

model ChoreAssignment {
  id             String           @id @default(cuid())
  choreId        String
  chore          Chore            @relation(fields: [choreId], references: [id], onDelete: Cascade)
  childAccountId String
  childAccount   ChildAccount     @relation(fields: [childAccountId], references: [id], onDelete: Cascade)
  dueDate        DateTime?
  completion     ChoreCompletion?
  createdAt      DateTime         @default(now())

  @@index([childAccountId])
  @@index([choreId])
}

model ChoreCompletion {
  id               String           @id @default(cuid())
  status           CompletionStatus @default(PENDING)
  assignmentId     String           @unique
  assignment       ChoreAssignment  @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  transaction      Transaction?
  approvedByUserId String?
  completedAt      DateTime         @default(now())
  approvedAt       DateTime?
}

model SavingGoal {
  id             String       @id @default(cuid())
  title          String
  targetCents    Int
  targetDate     DateTime?
  childAccountId String
  childAccount   ChildAccount @relation(fields: [childAccountId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([childAccountId])
}

model Investment {
  id                    String            @id @default(cuid())
  type                  InvestmentType
  status                InvestmentStatus  @default(ACTIVE)
  principalCents        Int
  currentBalanceCents   Int
  interestRateBps       Int
  termMonths            Int?
  startDate             DateTime          @default(now())
  maturityDate          DateTime?
  nextInterestAt        DateTime
  lastInterestAt        DateTime?
  withdrawalStatus      WithdrawalStatus?
  withdrawalRequestedAt DateTime?
  withdrawalApprovedAt  DateTime?
  withdrawalApprovedBy  String?
  childAccountId        String
  childAccount          ChildAccount      @relation(fields: [childAccountId], references: [id], onDelete: Cascade)
  familyId              String
  transactions          Transaction[]
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  @@index([childAccountId])
  @@index([familyId])
  @@index([nextInterestAt])
  @@index([status])
}
